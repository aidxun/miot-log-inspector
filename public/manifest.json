{
  "manifest_version": 3,
  "name": "MIoT Log Inspector",
  "description": "Inspect, search, and highlight full JSON messages in iot.mi.com MIoT device log tables.",
  "version": "0.1.0",
  "minimum_chrome_version": "114",
  "permissions": ["sidePanel", "scripting"],
  "host_permissions": ["https://iot.mi.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open MIoT Log Inspector",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://iot.mi.com/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
